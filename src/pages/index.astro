---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;

const breadcrumbs = JSON.stringify([{ label: "Northstar", href: base }, { label: "Home" }]);

const serviceMix = JSON.stringify([
  { label: "HVAC", value: 37 },
  { label: "Electrical", value: 28 },
  { label: "Facilities", value: 22 },
  { label: "Specialty", value: 13 },
]);

const proofColumns = JSON.stringify([
  { key: "customer", header: "Customer" },
  { key: "region", header: "Region" },
  { key: "result", header: "Result" },
]);

const proofRows = JSON.stringify([
  { customer: "Cedarline Health", region: "Upper Midwest", result: "18% faster closeout" },
  { customer: "Prairie Foods", region: "Great Plains", result: "41 sites synchronized" },
  { customer: "Beacon Retail", region: "Ohio Valley", result: "2.7 hour response gain" },
]);

const pathSteps = JSON.stringify([
  { id: "triage", label: "Triage", description: "Route urgent requests by site, trade, and SLA." },
  { id: "dispatch", label: "Dispatch", description: "Assign crews with parts, notes, and contact history." },
  { id: "proof", label: "Proof", description: "Capture closeout photos, signatures, and invoice context." },
]);
---

<BaseLayout title="Northstar Field Services | ApexUI Astro Demo">
  <main class="app-main">
    <div class="app-page">
      <apex-breadcrumbs items={breadcrumbs} label="Page breadcrumb"></apex-breadcrumbs>

      <section class="hero-band" aria-labelledby="hero-title">
        <div class="hero-copy">
          <apex-stack gap="lg">
            <apex-badge tone="success">Rose-light assigned theme</apex-badge>
            <apex-typography id="hero-title" as="h1" variant="display">
              Premium field operations for regional service teams
            </apex-typography>
            <apex-typography variant="body">
              Northstar Field Services coordinates urgent work orders, customer records, technician schedules, and executive proof in one routed Astro demo.
            </apex-typography>
            <div class="app-actions">
              <apex-button size="lg">Plan a rollout</apex-button>
              <apex-button variant="secondary" size="lg">Review operations</apex-button>
            </div>
          </apex-stack>
        </div>

        <div class="signal-panel">
          <apex-card eyebrow="Live board" heading="Today at a glance">
            <div class="metric-row">
              <span><strong>126</strong> open orders</span>
              <span><strong>94%</strong> SLA protected</span>
              <span><strong>18</strong> crews active</span>
            </div>
            <apex-chart label="Service mix" data={serviceMix}></apex-chart>
          </apex-card>
          <apex-alert tone="info" heading="Business story">
            Dispatch, customer success, and finance share the same source of truth instead of chasing updates through calls and spreadsheets.
          </apex-alert>
        </div>
      </section>

      <section class="app-section" aria-labelledby="offer-title">
        <div class="app-section-header">
          <div>
            <apex-typography id="offer-title" as="h2" variant="title">Northstar operating system</apex-typography>
            <apex-typography variant="body">Built for service companies with dense regional coverage and demanding commercial accounts.</apex-typography>
          </div>
          <apex-button-group label="Primary actions">
            <apex-button size="sm">Create order</apex-button>
            <apex-button size="sm" variant="secondary">Open dashboard</apex-button>
          </apex-button-group>
        </div>

        <div class="feature-grid">
          <apex-card eyebrow="Command" heading="SLA-aware dispatch">
            Assign work by trade, proximity, required equipment, and customer tier.
          </apex-card>
          <apex-card eyebrow="Records" heading="Commercial account memory">
            Keep site contacts, asset history, warranties, and notes ready before the technician arrives.
          </apex-card>
          <apex-card eyebrow="Proof" heading="Closeout evidence">
            Package photos, signatures, timestamps, and billing context for faster approval.
          </apex-card>
        </div>
      </section>

      <section class="app-section" aria-labelledby="proof-title">
        <div class="app-two-column">
          <div>
            <div class="app-section-header compact">
              <div>
                <apex-typography id="proof-title" as="h2" variant="title">Customer proof</apex-typography>
                <apex-typography variant="body">The fake business site still exercises real data, tables, charts, forms, and routed pages.</apex-typography>
              </div>
            </div>
            <apex-data-table caption="Customer outcomes" columns={proofColumns} rows={proofRows}></apex-data-table>
          </div>
          <apex-card eyebrow="Workflow" heading="From call to closeout">
            <apex-stepper steps={pathSteps} active-index="1"></apex-stepper>
            <apex-divider label="Next route"></apex-divider>
            <div class="app-actions">
              <apex-link href={`${base}dashboard/`}>View dashboard</apex-link>
              <apex-link href={`${base}work-orders/`}>Start work order</apex-link>
            </div>
          </apex-card>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
