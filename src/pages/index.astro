---
import BaseLayout from "../layouts/BaseLayout.astro";
const chartData = '[{ "label": "Tokens", "value": 92 }, { "label": "Components", "value": 84 }, { "label": "Routes", "value": 73 }]';
const rows = '[{ "area": "Tokens", "owner": "Platform", "status": "Live" }, { "area": "Components", "owner": "Design system", "status": "Beta" }, { "area": "Docs", "owner": "DX", "status": "Linked" }]';
const columns = '[{ "key": "area", "header": "Area" }, { "key": "owner", "header": "Owner" }, { "key": "status", "header": "Status" }]';
---
<BaseLayout><main class="demo-shell"><div class="demo-frame"><apex-app-bar title="ApexUI Astro Atlas"><apex-button size="sm">Build</apex-button></apex-app-bar><section class="demo-hero"><div class="demo-panel"><apex-stack gap="md"><apex-badge tone="info">Astro static-first</apex-badge><apex-typography as="h1" variant="display">Content route with live custom elements</apex-typography><apex-typography variant="body">Astro ships static markup and registers ApexUI custom elements once in the shared layout.</apex-typography><div class="demo-actions"><apex-button>Publish page</apex-button><apex-button variant="secondary">Open collection</apex-button></div><apex-search-form label="Find docs" placeholder="Search content"></apex-search-form></apex-stack></div><apex-card eyebrow="Static" title="Hydration only where needed"><apex-progress label="HTML first" value="96"></apex-progress><apex-rating label="Editorial fit" value="4"></apex-rating></apex-card></section><section class="demo-grid"><apex-chart label="Astro support" data={chartData}></apex-chart><apex-image-list items='["Tokens","Custom elements","Pages"]'></apex-image-list><apex-empty-state title="No island required" description="This page proves the custom-element path first."></apex-empty-state></section><apex-data-table caption="Astro matrix" columns={columns} rows={rows}></apex-data-table><apex-alert tone="success" title="Astro demo live">This repo installs @apexui/web-components from npm.</apex-alert></div></main></BaseLayout>
