---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;

const breadcrumbs = JSON.stringify([
  { label: "Northstar", href: base },
  { label: "Settings" },
]);

const localeOptions = JSON.stringify([
  { label: "English, United States", value: "en-US" },
  { label: "English, Canada", value: "en-CA" },
  { label: "Spanish, United States", value: "es-US" },
]);

const timezoneOptions = JSON.stringify([
  { label: "Eastern", value: "America/New_York" },
  { label: "Central", value: "America/Chicago" },
  { label: "Mountain", value: "America/Denver" },
  { label: "Pacific", value: "America/Los_Angeles" },
]);

const themeOptions = JSON.stringify([
  { label: "Rose light", value: "rose-light", description: "Default assigned theme for the demo." },
  { label: "Rose dark", value: "rose-dark", description: "Readable dark counterpart for smoke testing." },
]);

const tabs = JSON.stringify([
  { id: "profile", label: "Profile" },
  { id: "workspace", label: "Workspace" },
  { id: "alerts", label: "Alerts" },
]);
---

<BaseLayout title="Settings | Northstar Field Services">
  <main class="app-main">
    <div class="app-page">
      <apex-breadcrumbs items={breadcrumbs} label="Page breadcrumb"></apex-breadcrumbs>

      <section class="page-intro" aria-labelledby="settings-title">
        <div>
          <apex-badge tone="info">Account</apex-badge>
          <apex-typography id="settings-title" as="h1" variant="display">Settings and account</apex-typography>
          <apex-typography variant="body">
            Northstar preferences, locale, notification rules, and theme controls demonstrate a compact application settings surface.
          </apex-typography>
        </div>
        <apex-tabs label="Settings sections" items={tabs} active-id="workspace"></apex-tabs>
      </section>

      <section class="app-two-column app-two-column-wide" aria-label="Settings forms">
        <apex-card eyebrow="Profile" heading="Operator identity">
          <form class="app-form-grid">
            <apex-text-field label="Name" name="name" value="Ryan VerWey"></apex-text-field>
            <apex-text-field label="Email" name="email" type="email" value="ops@northstar.example"></apex-text-field>
            <apex-select label="Locale" name="locale" options={localeOptions} value="en-US"></apex-select>
            <apex-select label="Time zone" name="timezone" options={timezoneOptions} value="America/New_York"></apex-select>
            <div class="form-wide">
              <apex-radio-group
                label="Theme preference"
                name="theme"
                options={themeOptions}
                value="rose-light"
              ></apex-radio-group>
            </div>
            <div class="form-wide app-actions">
              <apex-button type="submit">Save settings</apex-button>
              <apex-button type="button" variant="secondary">Reset</apex-button>
            </div>
          </form>
        </apex-card>

        <div class="app-card-stack">
          <apex-card eyebrow="Workspace" heading="Dispatch defaults">
            <div class="record-list">
              <apex-switch label="Auto-assign same-day HVAC tickets" checked></apex-switch>
              <apex-switch label="Require closeout photo on premium accounts" checked></apex-switch>
              <apex-switch label="Hold invoices missing customer signature"></apex-switch>
            </div>
          </apex-card>
          <apex-card eyebrow="Alerts" heading="Notification rules">
            <div class="record-list">
              <apex-checkbox label="SLA risk email" description="Send when a priority ticket has less than one hour left." checked></apex-checkbox>
              <apex-checkbox label="Daily closeout digest" description="Summarize approvals ready for billing." checked></apex-checkbox>
              <apex-checkbox label="Pipeline renewal warning" description="Notify account owners before renewal risk rises."></apex-checkbox>
            </div>
          </apex-card>
        </div>
      </section>

      <section class="app-section" aria-labelledby="access-title">
        <div class="app-section-header">
          <div>
            <apex-typography id="access-title" as="h2" variant="title">Access controls</apex-typography>
            <apex-typography variant="body">Representative controls stay readable in rose-light and rose-dark.</apex-typography>
          </div>
          <apex-badge tone="success">Synced</apex-badge>
        </div>
        <div class="feature-grid">
          <apex-card eyebrow="Role" heading="Dispatch manager">
            Can edit routing rules, schedule crews, and approve emergency escalation.
          </apex-card>
          <apex-card eyebrow="Package" heading="Commercial operations">
            Includes customer records, pipeline views, SLA reporting, and proof packets.
          </apex-card>
          <apex-card eyebrow="Security" heading="Two-step review">
            High-value invoice changes require a second account lead before billing.
          </apex-card>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
